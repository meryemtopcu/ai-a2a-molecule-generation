   "source": [
    "from rdkit import Chem\n",
    "from rdkit.Chem import Draw\n",
    "\n",
    "suppl = Chem.SDMolSupplier(\"outputs2/4eiy_inpaint.sdf\", sanitize=False, removeHs=False)\n",
    "mols = [m for m in suppl if m is not None]\n",
    "img = Draw.MolsToGridImage(mols[:12], molsPerRow=4, subImgSize=(250, 250))\n",
    "img"
   ]
  }
